# Copy this file to .env and fill in your own values.
# Never commit the real .env file — it is already in .gitignore.

# --- Groq (LLM) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Gmail (fetch_email_tool.py, send_email_tool.py) ---
# Use a Gmail App Password, not your normal account password:
# https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# --- LangSmith tracing (send_email_tool.py, send_email_with_langsmith.py) ---
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=your_langsmith_project_name
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Notion (notion_tool.py) ---
NOTION_API_KEY=your_notion_integration_secret_here

# --- Twilio WhatsApp (whatsapp_tool.py) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Tavily (web search tool used in chatbot notebooks) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- Google Drive / Docs loader (LangChain-GoogleDocs/google_drive_loader.py) ---
# This script also requires a Google service-account credentials.json file
# placed at LangChain-GoogleDocs/credentials.json (not tracked in git).
